{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GeoServer Cloud DatasetRelease",
  "type": "object",
  "required": ["apiVersion", "kind", "spec"],
  "properties": {
    "apiVersion": { "const": "airgap.geoserver/v1" },
    "kind": { "const": "DatasetRelease" },
    "spec": {
      "type": "object",
      "required": ["collection", "release", "source", "publication"],
      "properties": {
        "collection": {
          "type": "object",
          "required": ["id", "title", "description", "license"],
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "title": { "type": "string", "minLength": 1 },
            "description": { "type": "string", "minLength": 1 },
            "license": { "type": "string", "minLength": 1 },
            "keywords": { "type": "array", "items": { "type": "string" } },
            "providers": { "type": "array", "items": { "type": "object" } }
          }
        },
        "release": {
          "type": "object",
          "required": ["version", "datetime"],
          "properties": {
            "version": { "type": "string", "minLength": 1 },
            "datetime": { "type": "string", "format": "date-time" }
          }
        },
        "source": {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "enum": ["vector", "raster"] },
            "layer": { "type": "string" }
          }
        },
        "publication": {
          "type": "object",
          "required": ["workspace"],
          "properties": {
            "workspace": { "type": "string", "minLength": 1 },
            "style": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  }
}
