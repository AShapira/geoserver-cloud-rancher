#!/usr/bin/env bash
set -euo pipefail

if [[ $# -lt 2 ]]; then
  echo "Usage: geoserver-rest METHOD REST_PATH [curl arguments...]" >&2
  echo "Example: geoserver-rest GET workspaces.json" >&2
  exit 2
fi

method="$1"
path="$2"
shift 2

exec curl --fail --silent --show-error \
  --user "${GEOSERVER_ADMIN_USERNAME}:${GEOSERVER_ADMIN_PASSWORD}" \
  --request "$method" \
  "${GEOSERVER_INTERNAL_URL%/}/rest/${path#/}" \
  "$@"
